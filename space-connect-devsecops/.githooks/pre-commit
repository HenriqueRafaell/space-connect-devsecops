#!/bin/bash

echo "🔍 Scanning for secrets before commit..."

if ! command -v detect-secrets &> /dev/null; then
    echo "⚠️  detect-secrets not installed. Run: pip install detect-secrets"
    exit 1
fi

detect-secrets scan --baseline .detectsecrets.json

if detect-secrets audit .detectsecrets.json --report 2>/dev/null | grep -q "PotentialSecret"; then
    echo "❌ SECRETS DETECTED! Commit aborted."
    echo "   Remove hardcoded secrets and use environment variables instead."
    exit 1
fi

STAGED_FILES=$(git diff --cached --name-only)

for FILE in $STAGED_FILES; do
    if [[ "$FILE" == *.py ]] || [[ "$FILE" == *.js ]] || [[ "$FILE" == *.ts ]] || [[ "$FILE" == *.yaml ]] || [[ "$FILE" == *.yml ]]; then
        if git show ":$FILE" 2>/dev/null | grep -qE "(sk_live|sk_test|AKIA[0-9A-Z]{16}|password\s*=\s*['\"][^'\"]+['\"]|api_key\s*=\s*['\"][^'\"]+['\"])"; then
            echo "❌ SECRETS DETECTED in $FILE! Commit aborted."
            exit 1
        fi
    fi
done

echo "✅ No secrets detected. Proceeding with commit."
exit 0
